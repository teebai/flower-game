{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": true
  },
  "include": ["server/**/*", "engine/**/*", "game/**/*", "types/**/*", "utils/**/*", "cards/**/*"],
  "exclude": ["node_modules", "dist", "src"]
}
